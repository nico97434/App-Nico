<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>INCA IMPORT — CRR Batch Réunion</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f4f7ff;--white:#fff;--border:#e2e8f8;--border2:#c7d2f0;
  --blue:#3b5bdb;--blue2:#4c6ef5;--blue3:#748ffc;--blue-soft:#eef2ff;
  --green:#0ca678;--green2:#12b886;--green-soft:#e6fcf5;
  --orange:#e8590c;--orange-soft:#fff4e6;
  --amber:#e67700;--amber-soft:#fff8e1;
  --red:#e03131;--red-soft:#fff5f5;
  --purple:#7048e8;--purple-soft:#f3f0ff;
  --teal:#0891b2;--teal-soft:#ecfeff;
  --text:#0f172a;--text2:#334155;--text3:#64748b;--text4:#94a3b8;
  --mono:'JetBrains Mono',monospace;--sans:'Plus Jakarta Sans',sans-serif;
  --r:12px;--r2:16px;
  --sh:0 1px 3px rgba(59,91,219,.08),0 4px 16px rgba(59,91,219,.06);
}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;font-size:14px}

/* HEADER */
.hdr{background:var(--white);border-bottom:1px solid var(--border);padding:0 2rem;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 4px 20px rgba(59,91,219,.06)}
.hdr-l{display:flex;align-items:center;gap:14px}
.logo{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;font-weight:800;font-size:11px;letter-spacing:2px;padding:6px 12px;border-radius:8px;text-transform:uppercase}
.hdr-title{font-size:17px;font-weight:700}
.hdr-sub{font-size:11px;color:var(--text3);margin-top:1px;font-weight:500}

.wrap{max-width:1400px;margin:0 auto;padding:1.5rem 2rem}

/* PARAMS BAR */
.params-bar{background:var(--white);border:1px solid var(--border);border-radius:var(--r2);padding:1.25rem 1.5rem;margin-bottom:1.5rem;box-shadow:var(--sh)}
.params-title{font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text3);margin-bottom:1rem;display:flex;align-items:center;gap:8px}
.params-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px}
.field{display:flex;flex-direction:column;gap:4px}
.field label{font-size:9px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text3)}
.inp-wrap{position:relative;display:flex;align-items:center}
.inp-wrap input,.inp-wrap select{width:100%;background:var(--bg);border:1.5px solid var(--border);border-radius:9px;padding:8px 12px;font-family:var(--mono);font-size:13px;font-weight:600;color:var(--text);outline:none;transition:all .2s}
.inp-wrap.has-suffix input{padding-right:36px}
.inp-wrap input:focus,.inp-wrap select:focus{border-color:var(--blue);background:var(--white);box-shadow:0 0 0 3px rgba(59,91,219,.1)}
.inp-suffix{position:absolute;right:10px;font-size:10px;font-weight:700;color:var(--text4);pointer-events:none;font-family:var(--mono)}

/* UPLOAD ZONE */
.upload-zone{background:var(--white);border:2px dashed var(--border2);border-radius:var(--r2);padding:2.5rem;text-align:center;cursor:pointer;transition:all .25s;margin-bottom:1.5rem}
.upload-zone:hover,.upload-zone.drag{border-color:var(--blue);background:var(--blue-soft)}
.upload-zone.drag{border-style:solid}
.upload-ico{font-size:40px;margin-bottom:.75rem}
.upload-title{font-size:16px;font-weight:700;color:var(--text);margin-bottom:.35rem}
.upload-sub{font-size:12px;color:var(--text3)}
.upload-formats{display:inline-flex;gap:6px;margin-top:.75rem}
.fmt-badge{background:var(--blue-soft);border:1px solid rgba(59,91,219,.2);padding:3px 10px;border-radius:20px;font-size:10px;font-weight:700;color:var(--blue)}
#fileInput{display:none}

/* STATUS BAR */
.status-bar{display:none;background:var(--green-soft);border:1px solid rgba(12,166,120,.2);border-radius:var(--r);padding:10px 16px;margin-bottom:1.25rem;display:flex;align-items:center;gap:10px;font-size:13px;font-weight:600;color:var(--green)}
.status-bar.error{background:var(--red-soft);border-color:rgba(224,49,49,.2);color:var(--red)}
.status-bar.hidden{display:none}

/* ACTIONS BAR */
.actions-bar{display:flex;align-items:center;gap:10px;margin-bottom:1.25rem;flex-wrap:wrap}
.btn{padding:9px 18px;border-radius:9px;font-family:var(--sans);font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;border:none;display:flex;align-items:center;gap:6px}
.btn-primary{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;box-shadow:0 2px 8px rgba(59,91,219,.3)}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(59,91,219,.4)}
.btn-secondary{background:var(--white);border:1.5px solid var(--border);color:var(--text2)}
.btn-secondary:hover{border-color:var(--blue);color:var(--blue)}
.btn-green{background:linear-gradient(135deg,var(--green),var(--green2));color:#fff;box-shadow:0 2px 8px rgba(12,166,120,.3)}
.btn-green:hover{transform:translateY(-1px)}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none!important}

.search-wrap{margin-left:auto;position:relative}
.search-wrap input{background:var(--white);border:1.5px solid var(--border);border-radius:9px;padding:8px 12px 8px 34px;font-size:13px;width:220px;outline:none;font-family:var(--sans)}
.search-wrap input:focus{border-color:var(--blue)}
.search-ico{position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:14px;pointer-events:none}

/* SUMMARY CARDS */
.summary-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:1.5rem}
.sum-card{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:1rem 1.25rem;box-shadow:var(--sh)}
.sum-v{font-family:var(--mono);font-size:22px;font-weight:800;color:var(--blue);line-height:1}
.sum-l{font-size:10px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);margin-top:4px}

/* TABLE */
.table-wrap{background:var(--white);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;box-shadow:var(--sh)}
.table-header{padding:1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.table-title{font-size:14px;font-weight:700}
.table-count{font-size:12px;color:var(--text3);font-weight:600}

table{width:100%;border-collapse:collapse;font-size:12px}
thead th{background:var(--bg);padding:10px 12px;font-size:9px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);text-align:left;border-bottom:2px solid var(--border);cursor:pointer;white-space:nowrap;user-select:none}
thead th:hover{color:var(--blue)}
thead th.sort-asc::after{content:' ▲';color:var(--blue)}
thead th.sort-desc::after{content:' ▼';color:var(--blue)}
tbody tr{border-bottom:1px solid var(--border);transition:background .15s}
tbody tr:hover{background:var(--blue-soft)}
tbody tr:last-child{border-bottom:none}
td{padding:10px 12px;vertical-align:middle}
.td-producer{font-size:10px;color:var(--text3);font-weight:600}
.td-product{font-weight:600;max-width:220px}
.td-barcode{font-family:var(--mono);font-size:10px;color:var(--text3)}
.td-price{font-family:var(--mono);font-weight:700}
.td-crr{font-family:var(--mono);font-weight:800;color:var(--blue)}
.td-margin{font-family:var(--mono);font-weight:700}
.td-margin.pos{color:var(--green)}
.td-margin.neg{color:var(--red)}
.td-bbd{font-size:10px;font-weight:600}
.td-bbd.ok{color:var(--green)}
.td-bbd.warn{color:var(--amber)}
.td-bbd.urgent{color:var(--red)}

/* PILL */
.pill{display:inline-block;padding:2px 8px;border-radius:20px;font-size:9px;font-weight:700;letter-spacing:.3px}
.pill-snack{background:var(--orange-soft);color:var(--orange)}
.pill-drink{background:var(--teal-soft);color:var(--teal)}
.pill-choco{background:var(--purple-soft);color:var(--purple)}
.pill-other{background:var(--bg);color:var(--text3);border:1px solid var(--border)}

/* DETAIL POPUP */
.popup-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:200;align-items:center;justify-content:center}
.popup-overlay.open{display:flex}
.popup{background:var(--white);border-radius:var(--r2);width:520px;max-height:85vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.popup-hdr{background:linear-gradient(135deg,#1e3a8a,var(--blue));color:#fff;padding:1.25rem 1.5rem;border-radius:var(--r2) var(--r2) 0 0;display:flex;justify-content:space-between;align-items:flex-start}
.popup-close{background:rgba(255,255,255,.2);border:none;color:#fff;font-size:18px;cursor:pointer;width:30px;height:30px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-left:1rem}
.popup-body{padding:1.5rem}
.detail-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px}
.detail-item:last-child{border-bottom:none}
.detail-label{color:var(--text3);font-weight:600}
.detail-val{font-family:var(--mono);font-weight:700}
.detail-item.total{background:var(--blue-soft);margin:0 -1.5rem;padding:10px 1.5rem;font-weight:800}
.detail-item.hl{background:var(--orange-soft);margin:0 -1.5rem;padding:8px 1.5rem}

/* EMPTY STATE */
.empty{text-align:center;padding:4rem 2rem;color:var(--text3)}
.empty-ico{font-size:48px;margin-bottom:1rem;opacity:.4}
.empty-title{font-size:16px;font-weight:700;color:var(--text2);margin-bottom:.5rem}
.empty-sub{font-size:13px}

/* PROGRESS */
.progress-bar{height:3px;background:var(--border);border-radius:2px;overflow:hidden;margin-bottom:1.5rem;display:none}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--blue2));border-radius:2px;transition:width .3s}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-l">
    <div class="logo">INCA IMPORT</div>
    <div>
      <div class="hdr-title">CRR Batch Calculator — Réunion</div>
      <div class="hdr-sub">Calcul du coût de revient rendu La Possession pour toute offre fournisseur</div>
    </div>
  </div>
  <button class="btn btn-green" onclick="exportExcel()" id="exportBtn" disabled>⬇ Exporter Excel</button>
</div>

<div class="wrap">

<!-- PARAMS -->
<div class="params-bar">
  <div class="params-title">⚙️ Paramètres CRR globaux — DSG Transit Repiquet MI251003405</div>
  <div class="params-grid">
    <div class="field">
      <label>Octroi de Mer V395</label>
      <div class="inp-wrap has-suffix"><input type="number" id="p_om" value="25.5" step="0.1"><span class="inp-suffix">%</span></div>
    </div>
    <div class="field">
      <label>OM Régional K949</label>
      <div class="inp-wrap has-suffix"><input type="number" id="p_omr" value="2.5" step="0.1"><span class="inp-suffix">%</span></div>
    </div>
    <div class="field">
      <label>Droit de douane</label>
      <div class="inp-wrap has-suffix"><input type="number" id="p_dd" value="9.6" step="0.1"><span class="inp-suffix">%</span></div>
    </div>
    <div class="field">
      <label>TVA import Réunion</label>
      <div class="inp-wrap has-suffix"><input type="number" id="p_tva" value="2.1" step="0.1"><span class="inp-suffix">%</span></div>
    </div>
    <div class="field">
      <label>Fret maritime 40'</label>
      <div class="inp-wrap has-suffix"><input type="number" id="p_fret" value="3850"><span class="inp-suffix">€</span></div>
    </div>
    <div class="field">
      <label>Frais transit DSG</label>
      <div class="inp-wrap has-suffix"><input type="number" id="p_dsg" value="1329"><span class="inp-suffix">€</span></div>
    </div>
    <div class="field">
      <label>Qté par conteneur (unités)</label>
      <div class="inp-wrap"><input type="number" id="p_qte" value="34560"></div>
    </div>
    <div class="field">
      <label>Stickering étiquetage FR</label>
      <div class="inp-wrap has-suffix"><input type="number" id="p_sticker" value="0.05" step="0.01"><span class="inp-suffix">€/u</span></div>
    </div>
    <div class="field">
      <label>Marge cible vente</label>
      <div class="inp-wrap has-suffix"><input type="number" id="p_margin" value="30" step="1"><span class="inp-suffix">%</span></div>
    </div>
    <div class="field">
      <label>Format conteneur</label>
      <div class="inp-wrap">
        <select id="p_ctnr" onchange="updateFret()">
          <option value="40" selected>40' HC DRY</option>
          <option value="20">20' DRY</option>
        </select>
      </div>
    </div>
  </div>
</div>

<!-- UPLOAD -->
<div class="upload-zone" id="uploadZone" onclick="document.getElementById('fileInput').click()" ondragover="onDrag(event)" ondragleave="offDrag(event)" ondrop="onDrop(event)">
  <div class="upload-ico">📂</div>
  <div class="upload-title">Glisser votre offre fournisseur ici ou cliquer pour choisir</div>
  <div class="upload-sub">Compatible avec le format Dabex et tout tableau fournisseur standard</div>
  <div class="upload-formats">
    <span class="fmt-badge">.xlsx</span>
    <span class="fmt-badge">.xls</span>
    <span class="fmt-badge">.csv</span>
  </div>
</div>
<input type="file" id="fileInput" accept=".xlsx,.xls,.csv" onchange="loadFile(this.files[0])">

<div class="progress-bar" id="progressBar"><div class="progress-fill" id="progressFill" style="width:0%"></div></div>

<div class="status-bar hidden" id="statusBar"></div>

<!-- SUMMARY -->
<div class="summary-row" id="summaryRow" style="display:none">
  <div class="sum-card"><div class="sum-v" id="s_produits">0</div><div class="sum-l">Produits analysés</div></div>
  <div class="sum-card"><div class="sum-v" id="s_crr_moy">—</div><div class="sum-l">CRR moyen / unité</div></div>
  <div class="sum-card"><div class="sum-v" id="s_margin_moy">—</div><div class="sum-l">Marge moyenne</div></div>
  <div class="sum-card"><div class="sum-v" id="s_pv_moy">—</div><div class="sum-l">PV conseillé moyen</div></div>
</div>

<!-- ACTIONS -->
<div class="actions-bar" id="actionsBar" style="display:none">
  <button class="btn btn-primary" onclick="recalcAll()">⚡ Recalculer tout</button>
  <button class="btn btn-secondary" onclick="resetFile()">🗑 Changer de fichier</button>
  <div class="search-wrap">
    <span class="search-ico">🔍</span>
    <input type="text" id="searchInput" placeholder="Filtrer produits..." oninput="filterTable()">
  </div>
</div>

<!-- TABLE -->
<div class="table-wrap" id="tableWrap">
  <div class="empty">
    <div class="empty-ico">📋</div>
    <div class="empty-title">Aucun fichier chargé</div>
    <div class="empty-sub">Importez votre offre fournisseur pour calculer automatiquement les CRR</div>
  </div>
</div>

</div><!-- /wrap -->

<!-- DETAIL POPUP -->
<div class="popup-overlay" id="popup" onclick="closePopup(event)">
  <div class="popup">
    <div class="popup-hdr">
      <div>
        <div style="font-size:11px;opacity:.7;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px">Détail CRR</div>
        <div style="font-size:15px;font-weight:700" id="popup-title">—</div>
      </div>
      <button class="popup-close" onclick="document.getElementById('popup').classList.remove('open')">✕</button>
    </div>
    <div class="popup-body" id="popup-body"></div>
  </div>
</div>

<script>
let allProducts = [];
let sortCol = null, sortDir = 1;

// ── Helpers ──────────────────────────────────────────────
const f2 = n => isNaN(n)||n==null ? '—' : new Intl.NumberFormat('fr-FR',{minimumFractionDigits:3,maximumFractionDigits:3}).format(n);
const f2s = n => isNaN(n)||n==null ? '—' : new Intl.NumberFormat('fr-FR',{minimumFractionDigits:2,maximumFractionDigits:2}).format(n);
const f0 = n => isNaN(n)||n==null ? '—' : new Intl.NumberFormat('fr-FR').format(Math.round(n));

function getP(id){ return parseFloat(document.getElementById(id).value)||0; }

function updateFret(){
  const v = document.getElementById('p_ctnr').value;
  document.getElementById('p_fret').value = v==='20' ? 3200 : 3850;
}

// ── CRR Calculation ───────────────────────────────────────
function calcCRR(prixUnit){
  const qte    = getP('p_qte') || 34560;
  const om     = getP('p_om') / 100;
  const omr    = getP('p_omr') / 100;
  const dd     = getP('p_dd') / 100;
  const tva    = getP('p_tva') / 100;
  const fret   = getP('p_fret');
  const dsg    = getP('p_dsg');
  const stk    = getP('p_sticker');
  const marg   = getP('p_margin') / 100;

  const valCAF      = prixUnit + fret / qte;
  const droitDD     = valCAF * dd;
  const omUnit      = valCAF * om;
  const omrUnit     = valCAF * omr;
  const baseTVA     = valCAF + droitDD + omUnit + omrUnit;
  const tvaUnit     = baseTVA * tva;
  const dsgUnit     = dsg / qte;
  const crr         = prixUnit + fret/qte + droitDD + omUnit + omrUnit + tvaUnit + dsgUnit + stk;
  const pvConseille = marg > 0 && marg < 1 ? crr / (1 - marg) : null;

  return { prixUnit, fretUnit: fret/qte, droitDD, omUnit, omrUnit, tvaUnit, dsgUnit, stkUnit: stk, crr, pvConseille, valCAF };
}

// ── File Loading ──────────────────────────────────────────
function onDrag(e){ e.preventDefault(); document.getElementById('uploadZone').classList.add('drag'); }
function offDrag(e){ document.getElementById('uploadZone').classList.remove('drag'); }
function onDrop(e){ e.preventDefault(); offDrag(e); loadFile(e.dataTransfer.files[0]); }

function loadFile(file){
  if(!file) return;
  setStatus('⏳ Lecture du fichier...', false);
  showProgress(20);
  const reader = new FileReader();
  reader.onload = e => {
    try {
      showProgress(50);
      const wb = XLSX.read(e.target.result, { type:'array', cellDates:true });
      const ws = wb.Sheets[wb.SheetNames[0]];
      const raw = XLSX.utils.sheet_to_json(ws, { header:1, defval:null });
      showProgress(75);
      parseSheet(raw, file.name);
      showProgress(100);
      setTimeout(()=>{ document.getElementById('progressBar').style.display='none'; }, 400);
    } catch(err){
      setStatus('❌ Erreur de lecture : ' + err.message, true);
      document.getElementById('progressBar').style.display='none';
    }
  };
  reader.readAsArrayBuffer(file);
}

function showProgress(pct){
  const pb = document.getElementById('progressBar');
  pb.style.display='block';
  document.getElementById('progressFill').style.width = pct+'%';
}

function parseSheet(rows, filename){
  // Detect header row — look for row containing "Price" or "prix"
  let headerIdx = -1;
  let colMap = {};

  for(let i=0; i<Math.min(rows.length,15); i++){
    const row = rows[i];
    if(!row) continue;
    const rowStr = row.map(c=>String(c||'').toLowerCase()).join('|');
    if(rowStr.includes('price') || rowStr.includes('prix') || rowStr.includes('product')){
      headerIdx = i;
      // Map columns
      row.forEach((cell, j) => {
        const c = String(cell||'').toLowerCase().trim();
        if(c.includes('product') || c.includes('produit') || c.includes('nom')) colMap.product = j;
        else if(c.includes('producer') || c.includes('brand') || c.includes('marque')) colMap.producer = j;
        else if(c.includes('barcode') || c.includes('ean') || c.includes('code')) colMap.barcode = j;
        else if(c.includes('price') || c.includes('prix')) colMap.price = j;
        else if(c.includes('pcs/case') || c.includes('pcs case') || c.includes('unités/carton')) colMap.pcsCase = j;
        else if(c.includes('pcs/pallet') || c.includes('palette')) colMap.pcsPallet = j;
        else if(c.includes('bbd') || c.includes('dlc') || c.includes('date') || c.includes('exp')) colMap.bbd = j;
        else if(c.includes('available') || c.includes('pallets') || c.includes('stock')) colMap.pallets = j;
        else if(c.includes('weight') || c.includes('poids')) colMap.weight = j;
        else if(c.includes('note') || c.includes('comment')) colMap.notes = j;
      });
      break;
    }
  }

  // Fallback: assume DABEX format (detected by col count ~17)
  if(headerIdx === -1 || Object.keys(colMap).length < 2){
    // DABEX specific: producer=0, product=2, barcode=3, pcsCase=4, pcsPallet=5, bbd=6, pallets=7, price=8, notes=9
    headerIdx = 5;
    colMap = { producer:0, product:2, barcode:3, pcsCase:4, pcsPallet:5, bbd:6, pallets:7, price:8, notes:9 };
  }

  const products = [];
  for(let i = headerIdx+1; i < rows.length; i++){
    const row = rows[i];
    if(!row) continue;
    const productName = row[colMap.product];
    const priceRaw = row[colMap.price];
    if(!productName || !priceRaw) continue;
    const price = parseFloat(String(priceRaw).replace(',','.'));
    if(isNaN(price) || price <= 0) continue;

    let bbdStr = '';
    if(colMap.bbd !== undefined && row[colMap.bbd]){
      const bbdVal = row[colMap.bbd];
      if(bbdVal instanceof Date) bbdStr = bbdVal.toLocaleDateString('fr-FR');
      else bbdStr = String(bbdVal);
    }

    products.push({
      id: i,
      producer: colMap.producer !== undefined ? (row[colMap.producer]||'') : '',
      product: String(productName).trim(),
      barcode: colMap.barcode !== undefined ? (row[colMap.barcode]||'') : '',
      pcsCase: colMap.pcsCase !== undefined ? (row[colMap.pcsCase]||'') : '',
      pcsPallet: colMap.pcsPallet !== undefined ? (row[colMap.pcsPallet]||'') : '',
      bbd: bbdStr,
      pallets: colMap.pallets !== undefined ? (row[colMap.pallets]||'') : '',
      price: price,
      notes: colMap.notes !== undefined ? (row[colMap.notes]||'') : '',
    });
  }

  if(products.length === 0){
    setStatus(`❌ Aucun produit détecté dans "${filename}". Vérifiez le format.`, true);
    return;
  }

  allProducts = products;
  setStatus(`✅ ${products.length} produits importés depuis "${filename}"`, false);
  recalcAll();
}

function recalcAll(){
  allProducts.forEach(p => {
    const r = calcCRR(p.price);
    Object.assign(p, r);
  });
  updateSummary();
  renderTable(allProducts);
  document.getElementById('summaryRow').style.display = 'grid';
  document.getElementById('actionsBar').style.display = 'flex';
  document.getElementById('exportBtn').disabled = false;
}

// ── Summary ───────────────────────────────────────────────
function updateSummary(){
  const n = allProducts.length;
  const avgCRR = allProducts.reduce((a,p)=>a+p.crr,0)/n;
  const avgPV = allProducts.filter(p=>p.pvConseille).reduce((a,p)=>a+(p.pvConseille||0),0)/(allProducts.filter(p=>p.pvConseille).length||1);
  const margin = getP('p_margin');
  document.getElementById('s_produits').textContent = f0(n);
  document.getElementById('s_crr_moy').textContent = '€ ' + f2s(avgCRR);
  document.getElementById('s_margin_moy').textContent = margin + ' %';
  document.getElementById('s_pv_moy').textContent = '€ ' + f2s(avgPV);
}

// ── Table Render ──────────────────────────────────────────
function categoryPill(name){
  const n = name.toLowerCase();
  if(n.includes('kinder')||n.includes('nutella')||n.includes('ferrero')||n.includes('choco')||n.includes('wafer')||n.includes('snickers')||n.includes('twix')||n.includes('mars')||n.includes('bounty')) return '<span class="pill pill-choco">🍫 Choco</span>';
  if(n.includes('monster')||n.includes('redbull')||n.includes('pokka')||n.includes('pepsi')||n.includes('cola')||n.includes('drink')||n.includes('boisson')||n.includes('juice')||n.includes('jus')) return '<span class="pill pill-drink">🥤 Boisson</span>';
  if(n.includes('chip')||n.includes('snack')||n.includes('cracker')||n.includes('popcorn')||n.includes('biscuit')||n.includes('cookie')||n.includes('pretzel')) return '<span class="pill pill-snack">🍿 Snack</span>';
  return '<span class="pill pill-other">📦 Autre</span>';
}

function bbdClass(bbdStr){
  if(!bbdStr) return '';
  // Try to parse date
  const parts = bbdStr.split(/[-\/\.]/);
  if(parts.length >= 3){
    let d;
    // Handle DD/MM/YYYY or YYYY-MM-DD
    if(parts[0].length === 4) d = new Date(parts[0], parts[1]-1, parts[2]);
    else d = new Date(parts[2], parts[1]-1, parts[0]);
    if(!isNaN(d)){
      const diff = (d - new Date()) / (1000*60*60*24);
      if(diff < 90) return 'urgent';
      if(diff < 180) return 'warn';
      return 'ok';
    }
  }
  return '';
}

let currentData = [];
function filterTable(){
  const q = document.getElementById('searchInput').value.toLowerCase();
  const filtered = q ? allProducts.filter(p =>
    p.product.toLowerCase().includes(q) ||
    p.producer.toLowerCase().includes(q) ||
    String(p.barcode).includes(q)
  ) : allProducts;
  renderTable(filtered);
}

function sortTable(col){
  if(sortCol === col) sortDir *= -1;
  else { sortCol = col; sortDir = 1; }
  filterTable();
}

function renderTable(data){
  currentData = [...data];
  if(sortCol){
    currentData.sort((a,b) => {
      const av = a[sortCol]||0, bv = b[sortCol]||0;
      return typeof av === 'string' ? av.localeCompare(bv)*sortDir : (av-bv)*sortDir;
    });
  }

  const cols = [
    {key:'producer', label:'Marque'},
    {key:'product', label:'Produit'},
    {key:'barcode', label:'EAN/Code'},
    {key:'price', label:'Prix FCA (€)'},
    {key:'crr', label:'CRR Réunion (€)'},
    {key:'pvConseille', label:'PV conseillé (€)'},
    {key:'bbd', label:'DLC'},
    {key:'pallets', label:'Palettes'},
    {key:'', label:'Détail'},
  ];

  const thead = cols.map(c => {
    const cls = sortCol===c.key ? (sortDir===1?'sort-asc':'sort-desc') : '';
    return `<th class="${cls}" onclick="${c.key?`sortTable('${c.key}')`:''}">  ${c.label}</th>`;
  }).join('');

  const tbody = currentData.map(p => {
    const bbdCls = bbdClass(p.bbd);
    const crr = p.crr;
    const pv = p.pvConseille;
    return `<tr>
      <td><div class="td-producer">${p.producer}</div>${categoryPill(p.product+' '+p.producer)}</td>
      <td class="td-product">${p.product}</td>
      <td class="td-barcode">${p.barcode||'—'}</td>
      <td class="td-price">€ ${f2(p.price)}</td>
      <td class="td-crr">€ ${f2(crr)}</td>
      <td class="td-price" style="color:var(--green)">${pv ? '€ '+f2(pv) : '—'}</td>
      <td class="td-bbd ${bbdCls}">${p.bbd||'—'}</td>
      <td style="font-family:var(--mono);font-size:11px">${p.pallets||'—'}</td>
      <td><button class="btn btn-secondary" style="padding:5px 10px;font-size:11px" onclick="showDetail(${p.id})">🔍 Voir</button></td>
    </tr>`;
  }).join('');

  document.getElementById('tableWrap').innerHTML = `
    <div class="table-header">
      <span class="table-title">📋 Résultats CRR — ${currentData.length} produit${currentData.length>1?'s':''}</span>
      <span class="table-count">Cliquer sur un en-tête pour trier · Cliquer "Voir" pour le détail complet</span>
    </div>
    <div style="overflow-x:auto">
      <table><thead><tr>${thead}</tr></thead><tbody>${tbody}</tbody></table>
    </div>`;
}

// ── Detail Popup ──────────────────────────────────────────
function showDetail(id){
  const p = allProducts.find(x=>x.id===id);
  if(!p) return;
  document.getElementById('popup-title').textContent = p.product;
  const qte = getP('p_qte');
  const fret = getP('p_fret');
  const rows = [
    {l:'Prix achat FCA fournisseur', v:'€ '+f2(p.price)},
    {l:`Fret maritime réparti (${f0(qte)} un.)`, v:'€ '+f2(p.fretUnit)},
    {l:`Droit de douane (${getP('p_dd')}% × CAF)`, v:'€ '+f2(p.droitDD), hl:true},
    {l:`Octroi de Mer (${getP('p_om')}% × CAF)`, v:'€ '+f2(p.omUnit), hl:true},
    {l:`OM Régional (${getP('p_omr')}% × CAF)`, v:'€ '+f2(p.omrUnit), hl:true},
    {l:`TVA import autoliquidée (${getP('p_tva')}%)`, v:'€ '+f2(p.tvaUnit)},
    {l:`Transit DSG réparti`, v:'€ '+f2(p.dsgUnit)},
    {l:'Stickering étiquetage FR', v:'€ '+f2(p.stkUnit)},
    {l:'🎯 CRR TOTAL rendu La Possession', v:'€ '+f2(p.crr), total:true},
    {l:`PV conseillé (${getP('p_margin')}% marge)`, v: p.pvConseille ? '€ '+f2(p.pvConseille) : '—'},
    {l:'Valeur CAF / unité', v:'€ '+f2(p.valCAF)},
  ];
  document.getElementById('popup-body').innerHTML = rows.map(r=>`
    <div class="detail-item ${r.total?'total':''} ${r.hl?'hl':''}">
      <span class="detail-label">${r.l}</span>
      <span class="detail-val">${r.v}</span>
    </div>`).join('') +
    `<div style="margin-top:1rem;padding:12px;background:var(--bg);border-radius:10px;font-size:11px;color:var(--text3)">
      <strong style="color:var(--text2);display:block;margin-bottom:4px">Informations produit</strong>
      EAN : ${p.barcode||'—'} · Pcs/carton : ${p.pcsCase||'—'} · Pcs/palette : ${p.pcsPallet||'—'}<br>
      DLC : ${p.bbd||'—'} · Palettes dispo : ${p.pallets||'—'}<br>
      ${p.notes ? 'Notes : '+p.notes : ''}
    </div>`;
  document.getElementById('popup').classList.add('open');
}

function closePopup(e){
  if(e.target.id==='popup') document.getElementById('popup').classList.remove('open');
}

// ── Export Excel ──────────────────────────────────────────
function exportExcel(){
  if(!allProducts.length) return;
  const qte = getP('p_qte');
  const rows = currentData.map(p => ({
    'Marque': p.producer,
    'Produit': p.product,
    'EAN': p.barcode,
    'Prix FCA (€)': p.price,
    'Fret/unité (€)': +(p.fretUnit||0).toFixed(4),
    'Droit douane (€)': +(p.droitDD||0).toFixed(4),
    'Octroi de Mer (€)': +(p.omUnit||0).toFixed(4),
    'OM Régional (€)': +(p.omrUnit||0).toFixed(4),
    'TVA import (€)': +(p.tvaUnit||0).toFixed(4),
    'Transit DSG (€)': +(p.dsgUnit||0).toFixed(4),
    'Stickering (€)': +(p.stkUnit||0).toFixed(4),
    'CRR La Possession (€)': +(p.crr||0).toFixed(4),
    'PV conseillé (€)': p.pvConseille ? +(p.pvConseille).toFixed(4) : '',
    'DLC': p.bbd,
    'Palettes dispo': p.pallets,
    'Pcs/carton': p.pcsCase,
    'Pcs/palette': p.pcsPallet,
  }));

  const params = [{
    'Paramètre': 'Octroi de Mer', 'Valeur': getP('p_om')+'%',
  },{
    'Paramètre': 'OM Régional', 'Valeur': getP('p_omr')+'%',
  },{
    'Paramètre': 'Droit de douane', 'Valeur': getP('p_dd')+'%',
  },{
    'Paramètre': 'TVA import', 'Valeur': getP('p_tva')+'%',
  },{
    'Paramètre': 'Fret maritime', 'Valeur': '€ '+getP('p_fret'),
  },{
    'Paramètre': 'Transit DSG total', 'Valeur': '€ '+getP('p_dsg'),
  },{
    'Paramètre': 'Qté conteneur', 'Valeur': getP('p_qte')+' unités',
  },{
    'Paramètre': 'Marge cible', 'Valeur': getP('p_margin')+'%',
  },{
    'Paramètre': 'Date export', 'Valeur': new Date().toLocaleDateString('fr-FR'),
  }];

  const wb = XLSX.utils.book_new();
  const ws1 = XLSX.utils.json_to_sheet(rows);
  const ws2 = XLSX.utils.json_to_sheet(params);

  // Style header row
  const range = XLSX.utils.decode_range(ws1['!ref']);
  for(let C = range.s.c; C <= range.e.c; C++){
    const addr = XLSX.utils.encode_cell({r:0, c:C});
    if(!ws1[addr]) continue;
  }

  XLSX.utils.book_append_sheet(wb, ws1, 'CRR Produits');
  XLSX.utils.book_append_sheet(wb, ws2, 'Paramètres CRR');

  const date = new Date().toISOString().slice(0,10);
  XLSX.writeFile(wb, `INCA_IMPORT_CRR_${date}.xlsx`);
}

// ── Misc ──────────────────────────────────────────────────
function setStatus(msg, isError){
  const el = document.getElementById('statusBar');
  el.textContent = msg;
  el.className = 'status-bar' + (isError?' error':'');
}

function resetFile(){
  allProducts = [];
  document.getElementById('fileInput').value = '';
  document.getElementById('tableWrap').innerHTML = `<div class="empty"><div class="empty-ico">📋</div><div class="empty-title">Aucun fichier chargé</div><div class="empty-sub">Importez votre offre fournisseur pour calculer automatiquement les CRR</div></div>`;
  document.getElementById('summaryRow').style.display = 'none';
  document.getElementById('actionsBar').style.display = 'none';
  document.getElementById('exportBtn').disabled = true;
  document.getElementById('statusBar').className = 'status-bar hidden';
}
</script>
